# Anthropic API key — crea una dedicada para Alivio en console.anthropic.com
# Nombre sugerido: "alivio-prod"
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Modelo a usar (default Haiku 4.5, cambiar a sonnet-4-6 si hay problemas de calidad)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Límite suave de mensajes por día por sesión (protege costos)
RATE_LIMIT_PER_DAY=30

# Webhook de n8n (cuando esté activo para orquestación y resúmenes)
# N8N_WEBHOOK_URL=https://n8n.intercapmm.com/webhook/alivio-chat

# Supabase (cuando integremos directorio y sesiones persistentes)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
